# Azure SQL — read side (SEO queries hit DA_Improvado for GSC + GA4)
AZURE_SQL_SERVER=daazure1.database.windows.net
AZURE_SQL_PORT=1433
AZURE_SQL_DATABASE=DA_Improvado
AZURE_SQL_USER=your_username
AZURE_SQL_PASSWORD=your_password

# Edge-auth (netlify/edge-functions/auth.js) — set BOTH on the Netlify site.
# Auth fails CLOSED (503) until both are present.
#   DA_AUTH_PASSWORD = the password the client types in
#   DA_AUTH_SECRET   = random 32-byte hex used to HMAC-sign the session cookie
DA_AUTH_PASSWORD=set_a_strong_password
DA_AUTH_SECRET=generate_with_openssl_rand_hex_32

# Optional shared secret for /api/cron-refresh — set both here and as a Netlify env var
CRON_SECRET=

# Scrunch AI Visibility — get from app.scrunchai.com > Organization > Settings > API Keys
SCRUNCH_API_KEY=

# Express server port (local dev only)
PORT=3001
